{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "database": {
      "type": "object",
      "properties": {
        "password": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["password"]
    },
    "agent": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "token": {
              "type": "string"
            }
          },
          "required": ["enabled"],
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "token": {
                "minLength": 1
              }
            },
            "required": ["token"]
          }
        }
      }
    }
  }
}
